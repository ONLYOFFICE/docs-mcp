{
  "name": "@onlyoffice/docs-mcp",
  "version": "0.0.1",
  "description": "ONLYOFFICE Docs Model Context Protocol Server",
  "keywords": [
    "onlyoffice",
    "docs",
    "modelcontextprotocol",
    "mcp"
  ],
  "homepage": "https://github.com/onlyoffice/docs-mcp/",
  "bugs": {
    "url": "https://github.com/onlyoffice/docs-mcp/issues/",
    "email": "support@onlyoffice.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ONLYOFFICE/docs-mcp"
  },
  "license": "MIT",
  "author": {
    "name": "Ascensio System SIA",
    "email": "integration@onlyoffice.com",
    "url": "https://onlyoffice.com/"
  },
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "bin": {
    "onlyoffice-docs-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node scripts/build.mjs",
    "watch": "cross-env INPUT=src/ext-apps/editor/index.html vite build --watch",
    "serve": "bun --watch src/index.ts",
    "serve:stdio": "bun --watch src/index.ts --stdio",
    "start": "cross-env NODE_ENV=development pnpm run build && pnpm run serve",
    "dev": "cross-env NODE_ENV=development concurrently --raw \"pnpm run watch\" \"pnpm run serve\"",
    "dev:stdio": "cross-env NODE_ENV=development concurrently --raw \"pnpm run watch\" \"pnpm run serve:stdio\""
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "bun": "^1.2.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-singlefile": "^2.3.2"
  },
    "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "bun"
    ]
  }
}
